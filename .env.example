# ============================================================
# Zaneva AI Platform — Environment Variables
# Copy file ini ke .env dan isi nilainya
# ============================================================

# Database
DATABASE_URL="postgresql://zaneva:zanevapass123@localhost:5432/zanevadb?schema=public"

# JWT Auth
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
# NODE_ENV: "development" untuk dev, "production" untuk monolith/docker
NODE_ENV="development"
PORT=3000

# FRONTEND_URL: hanya diperlukan di mode development (separated)
# Di production (monolith), variabel ini TIDAK perlu diset karena CORS dinonaktifkan
FRONTEND_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="./uploads"

# AI Providers (isi salah satu atau semua, aktifkan via UI Settings)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
