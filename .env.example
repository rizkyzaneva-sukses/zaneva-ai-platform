# Database
DATABASE_URL="postgresql://username:password@localhost:5432/zanevadb?schema=public"

# JWT Auth
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="./uploads"

# AI Providers (fill one or all, activate via DB/settings)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

BLACKBOX_API_KEY=""
BLACKBOX_MODEL="blackbox-ai"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
